# Development image used by docker-compose (runs in RAILS_ENV=development, so no
# master key or credentials are needed — a reviewer can `docker compose up` after cloning).
FROM ruby:3.3.11-slim

RUN apt-get update -qq && \
    apt-get install --no-install-recommends -y build-essential libpq-dev git && \
    rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY Gemfile Gemfile.lock ./
RUN bundle install

COPY . .

EXPOSE 3000

# Prepare + seed the database, then boot Puma bound to all interfaces.
CMD ["bash", "-c", "bundle exec rails db:prepare && bundle exec rails db:seed && bundle exec rails server -b 0.0.0.0"]
