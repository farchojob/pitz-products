# Backend environment template. Copy to backend/.env (gitignored, auto-loaded by
# dotenv-rails in development/test). For local Homebrew Postgres the defaults work
# with everything blank — the app connects over the socket as your OS user.

# --- Database ---
# Option A: a single connection URL (takes precedence, used by managed hosts):
# DATABASE_URL=postgres://user:password@localhost:5432/pitz_products_development
#
# Option B: discrete parts (leave blank for the local Homebrew socket):
POSTGRES_HOST=
POSTGRES_PORT=5432
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=pitz_products_development
POSTGRES_DB_TEST=pitz_products_test

RAILS_MAX_THREADS=5
PORT=3000

# --- CORS ---
# Comma-separated allowlist of frontend origins permitted to call the API.
FRONTEND_ORIGIN=http://localhost:5173
