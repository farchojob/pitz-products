# Root env template — used by docker-compose (see README).
# Copy to .env and adjust. NEVER commit the real .env.
#
# PostgreSQL (shared by the backend service and the db service)
POSTGRES_USER=pitz
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=pitz_products_development
POSTGRES_PORT=5432

# Ports exposed on the host
BACKEND_PORT=3000
FRONTEND_PORT=5173
