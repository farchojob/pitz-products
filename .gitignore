# ============================================================
# SECRETS — never commit real env files or keys
# (example templates are re-included below)
# ============================================================
.env
.env.*
*.env
!.env.example
!*.env.example
backend/config/master.key
backend/config/credentials/*.key

# ============================================================
# Local dev helper (resolved Ruby PATH for the keg-only brew ruby)
# ============================================================
.dev-env

# ============================================================
# OS / editor noise
# ============================================================
.DS_Store
Thumbs.db
.idea/
*.swp
*~

# Commit the shared VS Code debug/workspace config, ignore everything else under .vscode/
.vscode/*
!.vscode/launch.json
!.vscode/tasks.json
!.vscode/extensions.json
!.vscode/settings.json

# ============================================================
# Backend — Ruby on Rails
# ============================================================
backend/log/*
backend/tmp/*
backend/storage/*
backend/coverage/
backend/.bundle/
backend/vendor/bundle/
backend/public/assets/
!backend/log/.keep
!backend/tmp/.keep

# Runtime product-image uploads are local + ephemeral; committed seed images
# under public/uploads/seed/ ship with the demo so it has imagery out of the box.
backend/public/uploads/*
!backend/public/uploads/seed/
!backend/public/uploads/.keep

# ============================================================
# Frontend — Node / Vite
# ============================================================
frontend/node_modules/
frontend/dist/
frontend/coverage/
frontend/.vite/
frontend/*.local

# Design handoff reference bundle (HTML prototype) — kept local, not shipped.
frontend/design_handoff_premium_redesign/
