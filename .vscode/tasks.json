{
  "version": "2.0.0",
  "tasks": [
    {
      // Background task used as the preLaunchTask for the frontend debug config.
      // The problemMatcher lets VS Code know the server is "ready" once Vite prints
      // the "Local: http://localhost:5173/" line, so Chrome only launches after that.
      "label": "vite: dev",
      "type": "shell",
      "command": "npm run dev",
      "options": { "cwd": "${workspaceFolder}/frontend" },
      "isBackground": true,
      "problemMatcher": {
        "owner": "vite",
        "pattern": {
          "regexp": "^$"
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".*VITE v.*",
          "endsPattern": ".*Local:.*http.*"
        }
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "group": "fullstack"
      }
    },
    {
      // Convenience task to run the backend test suite from the Command Palette.
      "label": "backend: rspec",
      "type": "shell",
      "command": "bundle exec rspec",
      "options": {
        "cwd": "${workspaceFolder}/backend",
        "env": {
          "PATH": "/opt/homebrew/opt/ruby@3.3/bin:/opt/homebrew/lib/ruby/gems/3.3.0/bin:/opt/homebrew/opt/postgresql@16/bin:${env:PATH}"
        }
      },
      "group": "test",
      "problemMatcher": []
    }
  ]
}
